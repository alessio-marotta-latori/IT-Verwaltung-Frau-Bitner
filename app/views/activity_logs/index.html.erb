<div class="container mt-4">
  <h2>Aktivitätsprotokoll</h2>

  <table class="table table-bordered table-striped table-hover mt-3">
    <thead class="table-primary">
      <tr>
        <th>Zeitpunkt</th>
        <th>Aktion</th>
        <th>Typ</th>
        <th>Geräte-ID</th>
        <th>Details</th>
      </tr>
    </thead>
    <tbody>
      <% @activity_logs.each do |log| %>
        <tr>
          <td><%= log.created_at.strftime("%d.%m.%Y %H:%M") %></td>
          <td><%= log.action %></td>
          <td><%= log.trackable_type %></td>
          <td><%= log.trackable_id %></td>
          <td><%= log.details %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="mt-3">
    <%= link_to 'Zurück zur Device-Liste', devices_path, class: 'btn btn-light border' %>
  </div>
</div>
