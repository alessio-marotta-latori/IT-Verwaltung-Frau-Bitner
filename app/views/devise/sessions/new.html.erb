<% content_for :title, "Anmelden" %>

<section class="login-page">
  <div class="login-shell">
    <aside class="login-info-panel">
      <span class="login-info-kicker">IT-Verwaltung</span>
      <h1 class="login-info-title">Willkommen zur zentralen Geraeteverwaltung</h1>
      <p class="login-info-text">
        Melde dich mit deinem Konto an, um Geraete zu verwalten und Aktivitaeten nachzuverfolgen.
      </p>
    </aside>

    <div class="login-card">
      <h2 class="login-card-title">Anmelden</h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "login-form" }) do |f| %>
        <div class="login-field">
          <%= f.label :email, "E-Mail", class: "login-label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "login-input", placeholder: "name@firma.de" %>
        </div>

        <div class="login-field">
          <%= f.label :password, "Passwort", class: "login-label" %>
          <%= f.password_field :password, autocomplete: "current-password", class: "login-input", placeholder: "Dein Passwort" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="login-remember">
            <%= f.check_box :remember_me, class: "login-checkbox" %>
            <%= f.label :remember_me, "Angemeldet bleiben", class: "login-remember-label" %>
          </div>
        <% end %>

        <div class="login-actions">
          <%= f.submit "Anmelden", class: "login-submit" %>
        </div>
      <% end %>

      <div class="login-links">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</section>
