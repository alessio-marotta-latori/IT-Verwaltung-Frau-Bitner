<div class="container mt-4">
  <% if notice.present? %>
    <div class="alert alert-success"><%= notice %></div>
  <% end %>

  <h2>Gerät: <%= @device.hostname %></h2>

  <table class="table table-bordered mt-3">
    <tbody>
      <tr><th style="width:200px">Hostname</th><td><%= @device.hostname %></td></tr>
      <tr><th>IP-Adresse</th><td><%= @device.ip_address %></td></tr>
      <tr><th>MAC-Adresse</th><td><%= @device.mac_address %></td></tr>
      <tr><th>Gerätetyp</th><td><%= @device.device_type %></td></tr>
      <tr><th>Seriennummer</th><td><%= @device.serial_number %></td></tr>
      <tr><th>Kaufdatum</th><td><%= @device.purchase_date %></td></tr>
      <tr><th>Garantie bis</th><td><%= @device.warranty_until %></td></tr>
      <tr><th>Aktiv</th><td><%= @device.active ? 'Ja' : 'Nein' %></td></tr>
      <tr><th>Notizen</th><td><%= @device.notes %></td></tr>
    </tbody>
  </table>

  <div class="d-flex gap-2 mb-4">
    <%= link_to 'Bearbeiten', edit_device_path(@device), class: 'btn btn-outline-secondary' %>
    <%= link_to 'Zurück', devices_path, class: 'btn btn-outline-primary' %>
    <%= button_to 'Löschen', @device, method: :delete, class: 'btn btn-outline-danger', data: { confirm: 'Wirklich löschen?' } %>
  </div>

  <h4>Aktivitätsprotokoll</h4>
  <% logs = ActivityLog.where(trackable_type: "Device", trackable_id: @device.id).order(created_at: :desc) %>
  <% if logs.any? %>
    <table class="table table-striped table-bordered mt-2">
      <thead class="table-secondary">
        <tr>
          <th>Zeitpunkt</th>
          <th>Aktion</th>
          <th>Details</th>
        </tr>
      </thead>
      <tbody>
        <% logs.each do |log| %>
          <tr>
            <td><%= log.created_at.in_time_zone("Europe/Berlin").strftime("%d.%m.%Y %H:%M") %></td>
            <td><%= log.action %></td>
            <td><%= log.details %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-muted">Keine Aktivitäten vorhanden.</p>
  <% end %>
</div>
