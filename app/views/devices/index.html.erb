<div class="container mt-4">
  <h2>Device-Liste</h2>

  <table class="table table-bordered table-striped table-hover mt-3">
    <thead class="table-primary">
      <tr>
        <th>Hostname</th>
        <th>IP-Adresse</th>
        <th>Typ</th>
        <th>Aktiv</th>
        <th>Mac-Adresse</th>
        <th>Seriennummer</th>
        <th>Kauf am</th>
        <th>Garantie bis</th>
        <th>Notizen</th>
        <th>Aktionen</th>
      </tr>
    </thead>
    <tbody>
      <% @devices.each do |device| %>
        <tr>
          <td><%= device.hostname %></td>
          <td><%= device.ip_address %></td>
          <td><%= device.device_type %></td>
          <td><%= device.active ? 'True' : 'False' %></td>
          <td><%= device.mac_address %></td>
          <td><%= device.serial_number %></td>
          <td><%= device.purchase_date %></td>
          <td><%= device.warranty_until %></td>
          <td><%= device.notes %></td>
          <td>
            <%= link_to 'Ändern', edit_device_path(device), class: 'btn btn-sm btn-outline-secondary' %>
            <%= button_to 'Löschen', device, method: :delete, class: 'btn btn-sm btn-outline-danger mt-1', data: { confirm: 'Wirklich löschen?' } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="d-flex gap-2 mt-3">
    <%= link_to 'Neu', new_device_path, class: 'btn btn-light border' %>
    <%= link_to 'Neu Laden', devices_path, class: 'btn btn-light border' %>
    <%= link_to 'Aktivitätsprotokoll', activity_logs_path, class: 'btn btn-light border' %>
  </div>
</div>